# ── BYOK (свой ключ пользователя) ──────────────────────────────────────
# Ничего настраивать не нужно: ключ приходит в теле запроса, живёт только на время
# запроса, НЕ логируется и НЕ сохраняется. Бэкенд обязан это соблюдать.
#
# Пользователь вставляет ключ в Settings расширения (OpenAI / Claude / OpenAI-compat).

# ── Авторизация расширение → бэкенд (опционально) ─────────────────────
# Один статический Bearer-токен. Если пусто — авторизация выключена (локально).
BACKEND_AUTH_TOKEN=

# Порт HTTP-сервера. 8799 по умолчанию (8787 часто занят другими dev-серверами).
PORT=8799
