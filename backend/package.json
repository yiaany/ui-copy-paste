{
  "name": "ui-copy-paste-backend",
  "version": "0.1.0",
  "description": "Тонкий бэкенд-прокси UI Copy-Paste: ExtractedNode → React-компонент через LLM. Ключ LLM живёт только здесь.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.106.0",
    "@hono/node-server": "2.0.6",
    "dotenv": "17.4.2",
    "esbuild": "0.28.1",
    "hono": "4.12.27",
    "openai": "6.45.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
