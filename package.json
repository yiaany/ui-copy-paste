{
  "name": "ui-copy-paste",
  "version": "0.2.0",
  "description": "UI Copy-Paste — Chrome MV3 extension that copies any website UI into clean React + Tailwind components. BYOK (OpenAI / Claude / OpenAI-compatible).",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json,md}\"",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "framer-motion": "12.42.0",
    "lucide-react": "1.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.0",
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/chrome": "0.2.0",
    "@types/node": "26.0.1",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "7.3.6",
    "vitest": "4.1.9"
  }
}
